{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "slug": "section-overlay",
  "title": "Overlay",
  "blockTypes": ["core/group", "core/columns", "core/column"],
  "styles": {
    "color": {
      "background": "var(--mbf-color-overlay)",
      "text": "var(--mbf-color-primary-contrast)"
    },
    "blocks": {
      "core/separator": {
        "color": {
          "text": "var(--mbf-color-border)"
        }
      },
      "core/site-title": {
        "color": {
          "text": "var(--mbf-color-primary-contrast)"
        }
      },
      "core/site-tagline": {
        "color": {
          "text": "var(--mbf-color-primary-contrast)"
        }
      },
      "core/navigation": {
        "color": {
          "text": "var(--mbf-color-primary-contrast)"
        }
      }
    },
    "elements": {
      "caption": {
        "color": {
          "text": "var(--mbf-color-primary-contrast)"
        }
      },
      "heading": {
        "color": {
          "text": "var(--mbf-color-primary-contrast)"
        }
      },
      "link": {
        "color": {
          "text": "var(--mbf-color-primary-contrast)"
        }
      }
    }
  }
}
