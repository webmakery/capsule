{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "slug": "section-primary",
  "title": "Inverse Colors",
  "blockTypes": ["core/group", "core/columns", "core/column"],
  "styles": {
    "color": {
      "background": "var(--mbf-color-primary)",
      "text": "var(--mbf-color-primary-contrast)"
    },
    "blocks": {
      "core/separator": {
        "color": {
          "text": "var(--mbf-color-border-dark)"
        },
        "border": {
          "color": "var(--mbf-color-border-dark)",
          "width": "1px"
        }
      },
      "core/site-title": {
        "color": {
          "text": "var(--mbf-color-primary-contrast)"
        }
      },
      "core/site-tagline": {
        "color": {
          "text": "var(--mbf-color-primary-contrast)"
        }
      },
      "core/navigation": {
        "color": {
          "text": "var(--mbf-color-primary-contrast)"
        }
      },
      "core/navigation-submenu": {
        "color": {
          "text": "var(--mbf-color-primary-contrast)"
        },
        "elements": {
          "link": {
            "color": {
              "text": "var(--mbf-color-primary-contrast)"
            }
          }
        }
      }
    },
    "elements": {
      "caption": {
        "color": {
          "text": "var(--mbf-color-primary-contrast)"
        }
      },
      "button": {
        "color": {
          "background": "var(--mbf-color-button-contrast)",
          "text": "var(--mbf-color-button)"
        },
        ":hover": {
          "color": {
            "background": "color-mix(in srgb, var(--mbf-color-button-contrast) 85%, #000)"
          }
        }
      },
      "heading": {
        "color": {
          "text": "var(--mbf-color-primary-contrast)"
        }
      },
      "link": {
        "color": {
          "text": "var(--mbf-color-primary-contrast)"
        }
      }
    }
  }
}
