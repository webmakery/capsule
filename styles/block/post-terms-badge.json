{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "slug": "post-terms-badge",
  "title": "Badge",
  "blockTypes": ["core/post-terms"],
  "styles": {
    "elements": {
      "link": {
        "color": {
          "background": "var(--wp--preset--color--mbf-tag-bg)",
          "text": "var(--wp--preset--color--mbf-tag)"
        },
        "spacing": {
          "padding": {
            "top": "2px",
            "bottom": "2px",
            "left": "6px",
            "right": "6px"
          }
        },
        "border": {
          "radius": "2px"
        },
        "typography": {
          "fontSize": "var(--wp--preset--font-size--x-small)",
          "lineHeight": "1.3",
          "textDecoration": "none"
        }
      }
    }
  }
}
